    "import matplotlib.pyplot as plt\n",
    "\n",
    "df = pd.read_csv(\"../data/raw/runs.csv\")\n",
    "\n",
    "plt.plot(df[\"distance_miles\"], df[\"avg_hr\"])\n",
    "plt.xlabel(\"Distance (miles)\")\n",
    "plt.ylabel(\"Heart Rate\")\n",
    "plt.title(\"Heart Rate vs Distance\")\n",
    "plt.show()"
